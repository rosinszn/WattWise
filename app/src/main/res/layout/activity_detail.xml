<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#0F172A"
            android:padding="14dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/buttonBackDetail"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:text="← Back"
                android:textColor="#FFFFFF"
                android:backgroundTint="#334155" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bill Details"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />

            <Button
                android:id="@+id/buttonHomeDetail"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:text="Home"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2563EB" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Edit Electricity Bill"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#0F172A"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Update the bill information or delete the record."
                android:textSize="14sp"
                android:textColor="#64748B"
                android:layout_marginBottom="18dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:elevation="3dp"
                android:padding="18dp"
                android:layout_marginBottom="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Month"
                    android:textStyle="bold"
                    android:textColor="#334155" />

                <Spinner
                    android:id="@+id/spinnerMonthDetail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="#F8FAFC"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Electricity Usage (kWh)"
                    android:textStyle="bold"
                    android:textColor="#334155" />

                <EditText
                    android:id="@+id/editUnitDetail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Example: 250"
                    android:inputType="number"
                    android:background="#F8FAFC"
                    android:padding="12dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:id="@+id/textRebateDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Rebate: 0%"
                    android:textStyle="bold"
                    android:textColor="#334155" />

                <SeekBar
                    android:id="@+id/seekBarRebateDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="5"
                    android:layout_marginBottom="18dp" />

                <TextView
                    android:id="@+id/textTotalDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Total Charges: RM 0.00"
                    android:textSize="17sp"
                    android:textColor="#475569"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/textFinalDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Final Cost: RM 0.00"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#16A34A" />

            </LinearLayout>

            <Button
                android:id="@+id/buttonUpdate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Update Record"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#2563EB"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/buttonDelete"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Delete Record"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#DC2626" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>